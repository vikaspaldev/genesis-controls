# Required — shared secret used in "Authorization: Bearer <token>" header
API_SECRET=change-me-to-a-long-random-string

# ─── Future: Genesis Connected Services (Canada) ──────────────────────────────
# Uncomment when you're ready to wire up bluelinky:
#
# GENESIS_USERNAME=your-genesis-email@example.com
# GENESIS_PASSWORD=your-genesis-password
# GENESIS_PIN=1234
# GENESIS_VIN=KMHXXXXXXXXXXXXXX
# GENESIS_REGION=CA
# GENESIS_BRAND=hyundai
#
# bluelinky notes for Canada:
#   - brand is 'hyundai' (Genesis CA uses the HMG backend, not a separate brand)
#   - region must be 'CA'
#   - Canada uses undici fetch internally (bluelinky handles this automatically)
