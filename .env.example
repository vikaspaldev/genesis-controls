# Required — shared secret used in "Authorization: Bearer <token>" header
API_SECRET=change-me-to-a-long-random-string

# ─── Genesis Connected Services (Canada, genesisconnect.ca web portal) ────────
# All five below are required to enable the real car client.
# If GENESIS_USERNAME is missing, the API falls back to StubCarClient (mock).
GENESIS_USERNAME=your-genesis-email@example.com
GENESIS_PASSWORD=your-genesis-password
GENESIS_PIN=1234
# Base64-encoded browser fingerprint sent as the Deviceid header.
# Get this from your browser devtools on genesisconnect.ca (Network tab → any
# request → Deviceid header value).
GENESIS_DEVICE_ID=

# ─── Optional overrides ───────────────────────────────────────────────────────
# Pin a specific vehicle. If omitted, the first vehicle on the account is used.
# Format is the opaque base64 ID from the portal (e.g. "N/I9VcEocZbWoM5mvR5wWQ==").
# GENESIS_VEHICLE_ID=

# Override the Genesis API base URL (e.g. to point at a staging environment).
# GENESIS_BASE_URL=https://www.genesisconnect.ca/tods/api

# Override the browser User-Agent sent to Cloudflare.
# GENESIS_USER_AGENT=

# TTL (ms) for the cached PIN-verification pAuth code.
# start/stop always bypass the cache. Set to 0 to disable caching entirely.
# GENESIS_AUTH_CODE_TTL_MS=300000
