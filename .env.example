# Required — shared secret used in "Authorization: Bearer <token>" header
API_SECRET=change-me-to-a-long-random-string

# ─── Genesis Connected Services (Canada, genesisconnect.ca web portal) ────────
# Set all four to enable the real car client. If GENESIS_USERNAME is missing,
# the API falls back to StubCarClient (mock responses).
GENESIS_USERNAME=your-genesis-email@example.com
GENESIS_PASSWORD=your-genesis-password
GENESIS_PIN=1234

# Optional — pin a specific vehicle. If omitted, the first vehicle returned by
# /myvehicle is used. Format is the opaque base64-ish ID from the portal
# (e.g. "N/I9VcEocZbWoM5mvR5wWQ==").
# GENESIS_VEHICLE_ID=

# Optional — override the base64 browser fingerprint the portal expects on
# every request. Only change if the default stops being accepted.
# GENESIS_DEVICE_ID=

# Optional — TTL (milliseconds) for the cached PIN-verification pAuth. Lock
# and unlock reuse a fresh code within this window; remote start/stop always
# bypass the cache and re-verify the PIN. Set to 0 to disable caching entirely.
# GENESIS_AUTH_CODE_TTL_MS=300000
